<Page x:Class="WPFModernVerticalMenu.Pages.AddEditPages.AddOrder"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFModernVerticalMenu.Pages.AddEditPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddOrder">

    <Border Background="{DynamicResource PrimaryBackgroundColor}" CornerRadius="8" Margin="10">
        <Grid>
            <StackPanel>
                <Label Content="Номер заказа:" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                <TextBox Name="txtNum" Margin="2"/>
                <Label Content="Способ оплаты:" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"/>
                <ComboBox x:Name="PaymentMethodComboBox" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="2" SelectedIndex="0">
                    <ComboBoxItem Content="Наличные"/>
                    <ComboBoxItem Content="Безналичный расчет"/>
                    <ComboBoxItem Content="Кредитная карта"/>
                </ComboBox>

                <DataGrid x:Name="dgProducts" Margin="0,10,0,0" Background="Transparent" Foreground="Black" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название продукта" Width="auto" Binding="{Binding Product.productName}"/>
                        <DataGridTextColumn Header="Основные характеристики" Width="auto" Binding="{Binding Product.mainCharacteristics}"/>
                        <DataGridTextColumn Header="Цена" Width="auto" Binding="{Binding Product.price}"/>
                        <DataGridTextColumn Header="Количество" Width="auto" Binding="{Binding countProduct}"/>
                        <DataGridTemplateColumn>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Name="btnPlus" Content="+" Padding="3" Margin="5" Click="btnPlus_Click" Background="SteelBlue" Foreground="White" Visibility="{Binding vis}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Name="btnMinus" Content="-" Padding="3" Margin="5" Click="btnMinus_Click" Background="SteelBlue" Foreground="White" Visibility="{Binding vis}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="5">
                    <Button Name="btnAddProduct" Content="Добавить продукцию" Width="150" Click="AddProduct_Click" Background="SteelBlue" Foreground="White"/>
                    <Button Content="Сохранить" Width="75" Click="SaveButton_Click" Background="SteelBlue" Foreground="White" Margin="5 0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Page>
