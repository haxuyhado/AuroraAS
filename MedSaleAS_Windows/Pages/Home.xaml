<Page x:Class="WPFModernVerticalMenu.Pages.Home"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFModernVerticalMenu.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Home">

    <Grid Background="{DynamicResource SecundaryBackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>



        <StackPanel Grid.RowSpan="2" VerticalAlignment="Center" Margin="20">

            <TextBlock Text="Сменить пароль" FontWeight="Bold" FontSize="16" Foreground="White" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            <TextBlock Text="Старый пароль" Foreground="White" Margin="0,20,0,0" HorizontalAlignment="Center"/>
            <PasswordBox x:Name="txtOldPass" Width="300" Margin="0,10,0,10"/>
            <TextBlock Text="Новый пароль" Foreground="White" Margin="0,0,0,0" HorizontalAlignment="Center"/>
            <PasswordBox x:Name="txtNewPassword" Width="300" Margin="0,10,0,10"/>
            <TextBlock Text="Повторите пароль" Foreground="White" Margin="0,0,0,0" HorizontalAlignment="Center"/>
            <PasswordBox x:Name="txtNewPasswordReturn" Width="300" Margin="0,10,0,10"/>
            <Button x:Name="btnChangePassword" Content="Сменить пароль" Width="300" Margin="0,10,0,35" Click="btnChangePassword_Click"  Padding="3" Background="SteelBlue" BorderThickness="0" Foreground="White"/>
            <Button Name="btnLogot" Content="Выход" Background="Red" Width="300" Margin="0,10,0,35" Foreground="White" BorderThickness="0" Click="btnLogout_Click"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="Размер шрифта: " Foreground="White"/>
                <ComboBox Name="txtSize" SelectionChanged="txtSize_SelectionChanged" Width="200" BorderThickness="0" Background="White">
                    <ComboBoxItem>Маленький</ComboBoxItem>
                    <ComboBoxItem>Обычный</ComboBoxItem>
                    <ComboBoxItem>Крупный</ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
