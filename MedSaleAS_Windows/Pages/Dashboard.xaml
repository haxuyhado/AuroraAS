<Page x:Class="WPFModernVerticalMenu.Pages.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFModernVerticalMenu.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Dashboard">

    <Grid>
        <StackPanel Background="{DynamicResource SecundaryBackgroundColor}" Margin="20">
            <TextBlock Text="Список продукции" FontWeight="Bold" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>

            <ListView x:Name="lvProducts" Margin="0,10,0,0" Background="Transparent" Foreground="White" MouseDoubleClick="lvProducts_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Название продукта" Width="auto" DisplayMemberBinding="{Binding productName}"/>
                        <GridViewColumn Header="Основные характеристики" Width="auto" DisplayMemberBinding="{Binding mainCharacteristics}"/>
                        <GridViewColumn Header="Количество на складе" Width="auto" DisplayMemberBinding="{Binding countProduct}"/>
                        <GridViewColumn Header="Цена" Width="auto" DisplayMemberBinding="{Binding price}"/>
                    </GridView>
                </ListView.View>
            </ListView>
            <Button x:Name="btnAddProduct" Content="Добавить продукт" Width="300" Margin="0,10,0,0" Click="btnAddProduct_Click" Padding="3" Background="SteelBlue" BorderThickness="0" Foreground="White"/>
        </StackPanel>
    </Grid>
</Page>
