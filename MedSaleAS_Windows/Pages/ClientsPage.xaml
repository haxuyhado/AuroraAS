<Page x:Class="WPFModernVerticalMenu.Pages.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFModernVerticalMenu.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientsPage">

    <Grid>
        <StackPanel Background="{DynamicResource SecundaryBackgroundColor}" Grid.Row="1" Margin="20">
            <TextBlock Text="Список клиентов" FontWeight="Bold" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Foreground="White" Text="Поиск: " Margin="5"/>
                <TextBox Name="txtSearch" Margin="5" Width="200" TextChanged="txtSearch_TextChanged"/>
            </StackPanel>
            
            <ListView x:Name="lvClients" Margin="0,10,0,0" Background="Transparent" Foreground="White" MouseDoubleClick="lvClients_MouseDoubleClick" SelectionMode="Single" MouseRightButtonUp="lvClients_MouseRightButtonDown">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Компания" Width="auto" DisplayMemberBinding="{Binding recipientCompany}"/>
                        <GridViewColumn Header="ФИО" Width="auto" DisplayMemberBinding="{Binding recipientFullName}"/>
                        <GridViewColumn Header="Адрес" Width="auto" DisplayMemberBinding="{Binding address}"/>
                        <GridViewColumn Header="Телефон" Width="auto" DisplayMemberBinding="{Binding phone}"/>
                        <GridViewColumn Header="Email" Width="auto" DisplayMemberBinding="{Binding email}"/>
                        <GridViewColumn Header="ИНН" Width="auto" DisplayMemberBinding="{Binding INN}"/>
                        <GridViewColumn Header="ОГРН" Width="auto" DisplayMemberBinding="{Binding OGRN}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Button x:Name="btnAddClient" Content="Добавить клиента" Width="300" Margin="0,10,0,0" Click="btnAddClient_Click" Padding="3" Background="SteelBlue" BorderThickness="0" Foreground="White"/>
        </StackPanel>
    </Grid>
</Page>
