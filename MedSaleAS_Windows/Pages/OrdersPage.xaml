<Page x:Class="WPFModernVerticalMenu.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPFModernVerticalMenu.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrdersPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>



        <StackPanel Background="{DynamicResource SecundaryBackgroundColor}" Grid.RowSpan="2" Margin="20">
            <TextBlock Text="Список заказов" FontWeight="Bold" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Поиск: " Foreground="White" FontWeight="Bold" Margin="5"/>
                <TextBox Name="txtSearch" Margin="5" Width="200" TextChanged="txtSearch_TextChanged"/>
            </StackPanel>

            <ListView x:Name="lvOrders" Margin="0,10,0,0" Background="Transparent" Foreground="White" SelectionMode="Single" MouseDoubleClick="lvOrders_MouseDoubleClick" MouseRightButtonUp="lvOrders_MouseRightButtonUp">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Номер заказа" Width="auto" DisplayMemberBinding="{Binding orderNumber}"/>
                        <GridViewColumn Header="Клиент" Width="auto" DisplayMemberBinding="{Binding Client.recipientFullName}"/>
                        <GridViewColumn Header="Фирма" Width="auto" DisplayMemberBinding="{Binding Client.recipientCompany}"/>
                        <GridViewColumn Header="Способ оплаты" Width="auto" DisplayMemberBinding="{Binding paymentMethod}"/>
                        <GridViewColumn Header="Цена" Width="auto" DisplayMemberBinding="{Binding price}"/>
                        <GridViewColumn Header="Статус" Width="auto" DisplayMemberBinding="{Binding orderStatus}"/>
                        <GridViewColumn Header="Дата создания" Width="auto" DisplayMemberBinding="{Binding creationDate}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Button x:Name="btnAddOrder" Content="Добавить заказ" Width="300" Margin="0,10,0,0" Click="btnAddOrder_Click" Padding="3" Background="SteelBlue" BorderThickness="0" Foreground="White"/>
            <Button x:Name="btnPrint" Content="Заказы за период" Width="300" Margin="0,10,0,0" Click="btnPrint_Click" Padding="3" Background="SteelBlue" BorderThickness="0" Foreground="White"/>
        </StackPanel>
    </Grid>

</Page>
